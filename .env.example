# =============================================================================
# Buses Inteligentes - Docker Compose environment variables
# Copy this file to .env in the project root and fill in your values.
# Do NOT commit .env with real credentials.
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpass
DB_HOST=mysql
DB_PORT=3306
DB_USER=Joaquin
DB_PASS=Jacobo22
DB_NAME=ms_business_db

# --- MongoDB ---
MONGODB_DATABASE=db_security
MONGODB_URI=mongodb://mongo:27017/db_security

# --- ms-business (NestJS) ---
PORT=3000
MS_SECURITY=http://ms-security:8081
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:4200

# --- ms-security (Spring Boot) ---
SERVER_PORT=8081
JWT_SECRET=change-this-jwt-secret-before-production
JWT_EXPIRATION=3600000
FIREBASE_CREDENTIALS_PATH=file:/app/firebase-service-account.json
SECURITY_RECAPTCHA_SECRET_KEY=
SECURITY_PASSWORD_RECOVERY_RESET_URL=http://localhost:5173/reset-password
SECURITY_2FA_ENABLED=false
SECURITY_AUTHORIZATION_ENABLED=false
APP_MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=Notificaciones Buses <no-reply@buses-inteligentes.local>
BUSINESS_MS_URL=http://ms-business:3000

# --- ms-notifications (Flask) ---
NOTIFICATIONS_SERVER_PORT=8082
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATIONS_MAIL_FROM=notificaciones@buses-inteligentes.local
MAIL_FROM_NAME=Notificaciones Buses
APP_NAME=Buses Inteligentes
SUPPORT_EMAIL=soporte@buses-inteligentes.local

# --- client-app (Vite build args - browser-facing URLs) ---
VITE_API_URL=http://localhost:3000
VITE_API_URL_PERMISOS=http://localhost:8081/api
VITE_API_URL_SECURITY=http://localhost:8081/api/public/security
VITE_RECAPTCHA_SITE_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
VITE_EPAYCO_URL=https://checkout.epayco.co/checkout.js
VITE_EPAYCO_PUBLIC_KEY=
VITE_NOTIFICATIONS_URL=http://localhost:8082
VITE_N8N_PQRS_URL=
VITE_N8N_PQRS_ESTADO_URL=
VITE_N8N_CITAS_DISPONIBILIDAD_URL=
VITE_N8N_CITAS_AGENDAR_URL=
