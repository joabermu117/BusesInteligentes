# General backend config
SERVER_PORT=8081
MONGODB_DATABASE=db_security
MONGODB_URI=mongodb://localhost:27017/db_security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=3600000

# Microsoft OAuth (required to enable Microsoft login)
OAUTH_MICROSOFT_ENABLED=true
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_AUTHORIZE_URI=https://login.microsoftonline.com/common/oauth2/v2.0/authorize
OAUTH_MICROSOFT_TOKEN_URI=https://login.microsoftonline.com/common/oauth2/v2.0/token
OAUTH_MICROSOFT_USER_INFO_URI=https://graph.microsoft.com/v1.0/me
OAUTH_MICROSOFT_REDIRECT_URI=http://localhost:8081/api/public/security/oauth2/microsoft/callback
OAUTH_MICROSOFT_SCOPES=openid profile email User.Read

# Google OAuth (future)
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_AUTHORIZE_URI=
OAUTH_GOOGLE_TOKEN_URI=
OAUTH_GOOGLE_USER_INFO_URI=
OAUTH_GOOGLE_REDIRECT_URI=
OAUTH_GOOGLE_SCOPES=openid profile email

# GitHub OAuth (future)
OAUTH_GITHUB_ENABLED=false
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_AUTHORIZE_URI=
OAUTH_GITHUB_TOKEN_URI=
OAUTH_GITHUB_USER_INFO_URI=
OAUTH_GITHUB_REDIRECT_URI=
OAUTH_GITHUB_SCOPES=read:user user:email
