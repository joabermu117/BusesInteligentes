# General backend config
SERVER_PORT=8081
MONGODB_DATABASE=db_security
MONGODB_URI=mongodb://localhost:27017/db_security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=3600000
FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json

# reCAPTCHA v3
SECURITY_RECAPTCHA_ENABLED=true
SECURITY_RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret-key
SECURITY_RECAPTCHA_SCORE_THRESHOLD=0.5

# 2FA OTP configuration
SECURITY_OTP_TTL_SECONDS=300
SECURITY_OTP_MAX_ATTEMPTS=3
SECURITY_OTP_RESEND_COOLDOWN_SECONDS=30

# Password recovery
SECURITY_PASSWORD_RECOVERY_RESET_URL=http://localhost:5173/login
SECURITY_PASSWORD_RECOVERY_RATE_LIMIT_MAX_REQUESTS=5
SECURITY_PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_SECONDS=300

# Mail sender
APP_EMAIL_FROM=no-reply@busesinteligentes.local
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false


