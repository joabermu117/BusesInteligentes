# Stage 1: build
FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG VITE_API_URL=http://localhost:3000
ARG VITE_API_URL_PERMISOS=http://localhost:8081/api
ARG VITE_API_URL_SECURITY=http://localhost:8081/api/public/security
ARG VITE_RECAPTCHA_SITE_KEY=
ARG VITE_FIREBASE_API_KEY=
ARG VITE_FIREBASE_AUTH_DOMAIN=
ARG VITE_FIREBASE_PROJECT_ID=
ARG VITE_FIREBASE_STORAGE_BUCKET=
ARG VITE_FIREBASE_MESSAGING_SENDER_ID=
ARG VITE_FIREBASE_APP_ID=
ARG VITE_FIREBASE_MEASUREMENT_ID=
ARG VITE_FIREBASE_VAPID_KEY=
ARG VITE_EPAYCO_URL=https://checkout.epayco.co/checkout.js
ARG VITE_EPAYCO_PUBLIC_KEY=
ARG VITE_NOTIFICATIONS_URL=http://localhost:8082
ARG VITE_N8N_PQRS_URL=
ARG VITE_N8N_PQRS_ESTADO_URL=
ARG VITE_N8N_CITAS_DISPONIBILIDAD_URL=
ARG VITE_N8N_CITAS_AGENDAR_URL=
ARG VITE_N8N_CITAS_CANCELAR_URL=

ENV VITE_API_URL=$VITE_API_URL \
    VITE_API_URL_PERMISOS=$VITE_API_URL_PERMISOS \
    VITE_API_URL_SECURITY=$VITE_API_URL_SECURITY \
    VITE_RECAPTCHA_SITE_KEY=$VITE_RECAPTCHA_SITE_KEY \
    VITE_FIREBASE_API_KEY=$VITE_FIREBASE_API_KEY \
    VITE_FIREBASE_AUTH_DOMAIN=$VITE_FIREBASE_AUTH_DOMAIN \
    VITE_FIREBASE_PROJECT_ID=$VITE_FIREBASE_PROJECT_ID \
    VITE_FIREBASE_STORAGE_BUCKET=$VITE_FIREBASE_STORAGE_BUCKET \
    VITE_FIREBASE_MESSAGING_SENDER_ID=$VITE_FIREBASE_MESSAGING_SENDER_ID \
    VITE_FIREBASE_APP_ID=$VITE_FIREBASE_APP_ID \
    VITE_FIREBASE_MEASUREMENT_ID=$VITE_FIREBASE_MEASUREMENT_ID \
    VITE_FIREBASE_VAPID_KEY=$VITE_FIREBASE_VAPID_KEY \
    VITE_EPAYCO_URL=$VITE_EPAYCO_URL \
    VITE_EPAYCO_PUBLIC_KEY=$VITE_EPAYCO_PUBLIC_KEY \
    VITE_NOTIFICATIONS_URL=$VITE_NOTIFICATIONS_URL \
    VITE_N8N_PQRS_URL=$VITE_N8N_PQRS_URL \
    VITE_N8N_PQRS_ESTADO_URL=$VITE_N8N_PQRS_ESTADO_URL \
    VITE_N8N_CITAS_DISPONIBILIDAD_URL=$VITE_N8N_CITAS_DISPONIBILIDAD_URL \
    VITE_N8N_CITAS_AGENDAR_URL=$VITE_N8N_CITAS_AGENDAR_URL \
    VITE_N8N_CITAS_CANCELAR_URL=$VITE_N8N_CITAS_CANCELAR_URL

RUN npx vite build

# Stage 2: serve with nginx
FROM nginx:alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
